@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Shark WebAuthn library for .NET: complete server-side WebAuthn protocol implementation. Secure, passwordless login and MFA for modern web applications.">
    <title>Shark WebAuthn .NET library</title>
    <meta property="og:title" content="Shark WebAuthn .NET library" />
    <meta property="og:description" content="Shark WebAuthn library for .NET delivers a complete server-side WebAuthn implementation, enabling secure, passwordless login and MFA for modern web applications." />
    <meta property="og:image" content="https://shark-fido2.com/og-image.png" />
    <meta property="og:image:alt" content="Shark WebAuthn library for .NET – Secure passwordless authentication library" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content="https://shark-fido2.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Shark WebAuthn" />
    <meta property="og:locale" content="en_US" />
    <meta name="theme-color" content="#6366f1" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Shark WebAuthn .NET library" />
    <meta name="twitter:description" content="Shark WebAuthn library for .NET delivers a complete server-side WebAuthn implementation, enabling secure, passwordless login and MFA for modern web applications." />
    <meta name="twitter:image" content="https://shark-fido2.com/og-image.png" />
    <meta name="twitter:image:alt" content="Shark WebAuthn library for .NET – Secure passwordless authentication library" />
    <meta name="twitter:site" content="@@SharkWebAuthn" />
    <link rel="canonical" href="@($"{HttpContextAccessor!.HttpContext!.Request.Scheme}://{HttpContextAccessor.HttpContext.Request.Host}{HttpContextAccessor.HttpContext.Request.Path}{HttpContextAccessor.HttpContext.Request.QueryString}")" />
    <link rel="icon" href="favicon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="~/manifest.json" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/font-awesome/dist/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/notyf/dist/css/notyf.min.css" />
    <link rel="stylesheet" href="~/lib/prism/dist/css/prism-vs.min.css" />
    <link rel="stylesheet" href="~/lib/prism/dist/css/prism-line-numbers.min.css" />
    <environment include="Development">
        <link rel="stylesheet" href="~/css/site.css" />
        <link rel="stylesheet" href="~/css/landing.css" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet" href="~/css/site.min.css" />
        <link rel="stylesheet" href="~/css/landing.min.css" />
    </environment>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand banner" href="/">
                    <i class="me2">
                        <svg width="24" height="24" viewBox="0 0 24 22" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                            <path d="M14.422 19.4878H0.728094C0.728094 19.4624 0.728094 19.438 0.728094 19.4135C0.728094 18.7085 0.718798 18.0033 0.730573 17.2986C0.752883 15.9622 1.15385 14.7469 1.94122 13.6655C2.73231 12.5788 3.77222 11.8245 5.04329 11.391C5.66302 11.1797 6.3029 11.0691 6.95764 11.0657C8.09361 11.0598 9.22989 11.0576 10.3659 11.0657C11.1796 11.0713 11.9632 11.2389 12.7137 11.5556C12.7512 11.5714 12.7893 11.6095 12.8067 11.6467C13.172 12.4359 13.6926 13.1031 14.3718 13.6463C14.4074 13.6748 14.4232 13.7023 14.4229 13.7488C14.4217 15.639 14.422 17.5292 14.422 19.4194C14.422 19.4395 14.422 19.46 14.422 19.4878Z" fill="#1f2937" />
                            <path d="M13.3681 4.73909C13.3684 7.35467 11.2443 9.47974 8.629 9.48005C6.01033 9.48005 3.88712 7.35436 3.88867 4.7329C3.88991 2.1198 6.01714 -0.00123892 8.6352 5.42951e-07C11.2449 0.00124001 13.3678 2.12723 13.3681 4.73909Z" fill="#1f2937" />
                            <path d="M18.9124 12.9177C19.35 13.3552 19.78 13.7853 20.2126 14.2176C19.6837 14.7462 19.1606 15.2693 18.6348 15.7951C19.1668 16.3272 19.6902 16.8505 20.2064 17.3668C19.3245 18.2486 18.451 19.1225 17.5735 19.9997C17.5636 19.9904 17.5444 19.9743 17.5264 19.9563C17.0368 19.467 16.5478 18.9771 16.0573 18.4891C16.0192 18.4513 16.0049 18.4138 16.0049 18.3605C16.0062 16.5373 16.0056 14.714 16.0077 12.8908C16.0077 12.8213 15.9867 12.7897 15.925 12.7575C14.8845 12.2118 14.2229 11.3681 13.9787 10.2175C13.5697 8.29079 14.7825 6.37706 16.6978 5.90451C18.6382 5.42577 20.6077 6.56855 21.1329 8.49871C21.458 9.69293 21.2222 10.7896 20.4664 11.7687C20.0716 12.2803 19.5631 12.6478 18.9657 12.8929C18.9515 12.8988 18.9378 12.9059 18.9124 12.918V12.9177ZM17.5862 9.48316C18.1672 9.48285 18.6397 9.00999 18.64 8.42868C18.64 7.84706 18.1684 7.37359 17.5874 7.37297C17.0018 7.37235 16.5289 7.84551 16.5299 8.43147C16.5308 9.01216 17.0043 9.48378 17.5862 9.48347V9.48316Z" fill="#1f2937" />
                        </svg>
                    </i>Shark WebAuthn
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Documentation">Documentation</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/DiscoverableCredentials">Try It: Discoverable Credentials</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/NonDiscoverableCredentials">Try It: Non-discoverable Credentials</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/ConditionalMediation">Try It: Conditional UI</a>
                        </li>
                    </ul>
                    <a href="https://github.com/linuxchata/fido2" target="_blank" class="btn btn-outline ms-auto btn-github">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="me-2">
                            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
                        </svg>
                        GitHub
                    </a>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <p>&copy; 2024-2026 Shark WebAuthn .NET library</p>
        <p class="mt-2">FIDO&reg; and FIDO2&reg; are trademarks of FIDO Alliance, Inc.</p>
        <p class="mt-2">
            <a asp-page="/PrivacyPolicy" class="text-white mx-2">Privacy Policy</a>
            <span class="text-white-50">|</span>
            <a asp-page="/TermsOfService" class="text-white mx-2">Terms of Service</a>
        </p>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/notyf/dist/js/notyf.min.js"></script>
    <script src="~/lib/prism/dist/js/prism.min.js"></script>
    <script src="~/lib/prism/dist/js/languages/prism-csharp.min.js"></script>
    <script src="~/lib/prism/dist/js/languages/prism-json.min.js"></script>
    <script src="~/lib/prism/dist/js/languages/prism-bash.min.js"></script>
    <script src="~/lib/prism/dist/js/languages/prism-javascript.min.js"></script>
    <environment include="Development">
        <script src="~/js/common/utilities.js"></script>
        <script src="~/js/common/assertion.js"></script>
        <script src="~/js/common/attestation.js"></script>
        <script src="~/js/common/code-highlight.js"></script>
        <script src="~/js/common/nav-highlight.js"></script>
        <script src="~/js/common/notifications.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/js/common.min.js"></script>
        <script src="~/js/gtm.min.js"></script>
        <!-- Google tag (gtag.js) -->
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-3C7WCLK2W4"></script>
    </environment>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
